#!/bin/bash
{
	#////////////////////////////////////
	# shaughvOS Login Script
	#
	#////////////////////////////////////
	# Created by Daniel Knight / daniel.knight@dietpi.com / dietpi.com
	#
	#////////////////////////////////////
	#
	# Info:
	# - Location: /boot/shaughvos/shaughvos-login
	# - Called in interactive bash shells from: /etc/bashrc.d/shaughvos.bash
	#////////////////////////////////////

	#/////////////////////////////////////////////////////////////////////////////////////
	# Globals
	#/////////////////////////////////////////////////////////////////////////////////////
	readonly FP_SHAUGHVOS_FIRSTRUNSETUP_LOG='/var/tmp/shaughvos/logs/shaughvos-firstrun-setup.log'
	readonly FP_SHAUGHVOS_FIRSTRUNSETUP_PID='/tmp/.shaughvos-login_firstrun_setup.pid' # PID and flag to detect and avoid concurrent first run setup
	readonly FP_SHAUGHVOS_FIRSTRUNSETUP_ERR='/tmp/.shaughvos-login_firstrun_setup_err' # Error flag to allow a second instance kill and repeat first run setup

	# AutoStart after autologin
	# - $1: AutoStart index
	Run_AutoStart()
	{
		local auto_start_index=$1

		# Kodi
		if (( $auto_start_index == 1 ))
		then
			exec kodi --standalone

		# Desktop autologin (for root user only, as non-root user autologins are done via LightDM service since v7.2)
		elif (( $auto_start_index == 2 ))
		then
			unset -v G_SHAUGHVOS_LOGIN
			exec startx

		# OpenTyrian
		elif (( $auto_start_index == 4 ))
		then
			exec /usr/games/opentyrian/run

		# shaughvOS-CloudShell
		elif (( $auto_start_index == 5 ))
		then
			exec /boot/shaughvos/shaughvos-cloudshell 1

		# Amiberry standard boot
		elif (( $auto_start_index == 8 ))
		then
			exec systemctl start amiberry

		# DXX-Rebirth
		elif (( $auto_start_index == 9 ))
		then
			exec /mnt/shaughvos_userdata/dxx-rebirth/run.sh

		# CAVA
		elif (( $auto_start_index == 10 ))
		then
			# Disable screen blanking
			setterm --blank 0 --powersave off

			# Wait for MPD FIFO
			local count=1 timeout=10
			until [[ -e '/tmp/mpd.fifo' ]]
			do
				(( $count > $timeout )) && { echo '[FAILED] Waiting for MPD FIFO timed out. Aborting...'; return 1; }
				echo "[ INFO ] Waiting for MPD FIFO before starting CAVA ($count/$timeout)"
				sleep 1
				((count++))
			done

			# Start CAVA
			exec cava

		# Chromium
		elif (( $auto_start_index == 11 ))
		then
			exec /var/lib/shaughvos/shaughvos-software/installed/chromium-autostart.sh

		# Custom script after autologin
		elif [[ $auto_start_index == 17 && -f '/var/lib/shaughvos/shaughvos-autostart/custom.sh' ]]
		then
			chmod +x /var/lib/shaughvos/shaughvos-autostart/custom.sh
			echo '[ INFO ] Starting shaughvOS-AutoStart custom script...'
			exec /var/lib/shaughvos/shaughvos-autostart/custom.sh
		fi
	}

	# Force interactive prompt on unexpected state or failure, to allow user choice to retry or exit
	Prompt_on_Failure()
	{
		/boot/shaughvos/func/shaughvos-banner 0

		# Force interactive mode to show G_WHIP error prompts
		# - NB: We need to write this to shaughvos.txt as well to not have it overwritten on next loop.
		export G_INTERACTIVE=1
		G_CONFIG_INJECT 'AUTO_SETUP_AUTOMATED=' 'AUTO_SETUP_AUTOMATED=0' /boot/shaughvos.txt
		# - Disable autologin, which is forced with AUTO_SETUP_AUTOMATED=1, but not needed for an interactive setup.
		#   Furthermore it causes issues when the interactive setup is not wanted via TTY1 but via SSH or serial console: https://github.com/RealEmmettS/shaughvOS/issues/4555#issuecomment-908944285
		rm -f /etc/systemd/system/{getty@tty1,console-getty}.service.d/shaughvos-autologin.conf

		local pid_loginerror=$$
		[[ -f $FP_SHAUGHVOS_FIRSTRUNSETUP_ERR ]] && pid_loginerror=$(<"$FP_SHAUGHVOS_FIRSTRUNSETUP_ERR")
		if [[ $pid_loginerror != "$$" ]]
		then
			G_WHIP_BUTTON_OK_TEXT='Take over' G_WHIP_BUTTON_CANCEL_TEXT='Retry'
			G_WHIP_DEFAULT_ITEM='yes' G_WHIP_YESNO "[FAILED] Unknown install state/First run setup failed on another screen (PID=$pid_loginerror).
\nYou can <Take over> the error handling on this screen and kill the other shaughvOS-Login session.
\nElse you can finish the error handling on the other shaughvOS-Login session and <Retry> the login script on this session afterwards." || return
			kill -9 "$pid_loginerror"
			[[ -f $FP_SHAUGHVOS_FIRSTRUNSETUP_PID ]] && rm "$FP_SHAUGHVOS_FIRSTRUNSETUP_PID"
		fi

		echo $$ > "$FP_SHAUGHVOS_FIRSTRUNSETUP_ERR"
		if G_WHIP_DEFAULT_ITEM='yes' G_WHIP_YESNO "[FAILED] Unknown install state/First run setup failed\n
An error has occurred either during first run update or installs.\n
First run setup will now attempt to re-apply the last step, forced as interactive run.
If this repeatedly fails, please collect all terminal output and the content of $FP_SHAUGHVOS_FIRSTRUNSETUP_LOG if available and report this issue to: https://github.com/RealEmmettS/shaughvOS/issues\n
Would you like to restart the first run setup and installation?"
		then
			# Reset and force re-run of first run setup
			rm "$FP_SHAUGHVOS_FIRSTRUNSETUP_ERR"
			killall -qw shaughvos-software shaughvos-update
			echo 0 > /boot/shaughvos/.install_stage

		else
			rm "$FP_SHAUGHVOS_FIRSTRUNSETUP_ERR"
			exit 1
		fi
	}

	# First Run Setup
	Run_shaughvOS_First_Run_Setup()
	{
		# Set non-interactive if automated first run setup has been chosen
		grep -q '^[[:blank:]]*AUTO_SETUP_AUTOMATED=1' /boot/shaughvos.txt && export G_INTERACTIVE=0

		# Prompt and wait if this script runs in other session already
		local pid_firstrunsetup=$$
		[[ -f $FP_SHAUGHVOS_FIRSTRUNSETUP_PID ]] && pid_firstrunsetup=$(<"$FP_SHAUGHVOS_FIRSTRUNSETUP_PID")

		# Unknown install state/First run setup failed in other session, forcing interactive whiptail prompt. Allow to take over and repeat on this session.
		if [[ -f $FP_SHAUGHVOS_FIRSTRUNSETUP_ERR ]]
		then
			Prompt_on_Failure

		elif [[ $pid_firstrunsetup != "$$" ]]
		then
			local additional_text='Please resume setup on the active screen.'
			[[ $G_INTERACTIVE == 0 ]] && additional_text='Automated setup is in progress. The system might be rebooted in between.'

			G_WHIP_MSG "[ INFO ] shaughvOS first run setup is currently running on another screen (PID=$pid_firstrunsetup).\n\n$additional_text"

			local restart_loop_delay=5
			G_SHAUGHVOS-NOTIFY 2 "Waiting $restart_loop_delay seconds before checking again. Please wait... (Press CTRL+C to abort)"
			G_SLEEP "$restart_loop_delay"

		elif (( $EUID ))
		then
			G_WHIP_MSG '[ WARN ] root permissions required
\nTo finish the shaughvOS first run setup, this script will now try to rerun itself with "sudo".
\nIf this fails, please login as user "root" with password "1234", respectively the one you chose via "shaughvos.txt".'
			G_CHECK_ROOT_USER
			exit 1

		# Proceed with 1st run setup
		else
			# Prevent re-run from another session.
			echo $$ > "$FP_SHAUGHVOS_FIRSTRUNSETUP_PID"
			# - Always remove PID file when script is exited/terminated/killed
			trap '[[ -f $FP_SHAUGHVOS_FIRSTRUNSETUP_PID ]] && rm $FP_SHAUGHVOS_FIRSTRUNSETUP_PID' EXIT

			if [[ $G_SHAUGHVOS_INSTALL_STAGE == 0 && $(findmnt -Ufnro FSTYPE -M /) == 'ext'[34] ]] && { [[ ! -e $G_ROOTFS_DEV ]] || ! tune2fs -l "$G_ROOTFS_DEV" | grep -q 'has_journal'; }
			then
				# Allow to proceed if $G_ROOTFS_DEV does not exist, where we assume the image was started as container without block device access
				if [[ -e $G_ROOTFS_DEV ]]
				then
					# shellcheck disable=SC2016
					G_WHIP_MSG '[FAILED] ext3 or ext4 rootfs without journal detected
\next3 and ext4 root filesystems are expected to contain a filesystem journal to protect against data loss. That it is missing is most likely the result of a failed resize script. Please collect the output of the following commands and open an issue on our GitHub repository or forum:
\njournalctl -u shaughvos-fs_partition_resize
cat /var/tmp/shaughvos/logs/fs_partition_resize.log
\nGitHub: https://github.com/RealEmmettS/shaughvOS/issues
Discussions: https://github.com/RealEmmettS/shaughvOS/discussions
\nIf you aim to solve this yourself, the resize script is located at /var/lib/shaughvos/services/fs_partition_resize.sh. Alternatively, a journal can be added with "tune2fs -j $G_ROOTFS_DEV".
Let us know if you actually intend to run this system without journal. This check is done on first boot only, hence adding it temporarily and removing it afterwards works.'

					exit 1
				else
					G_WHIP_MSG "[ WARN ] ext3 or ext4 rootfs without journal detected
\next3 and ext4 root filesystems are expected to contain a filesystem journal to protect against data loss. It is missing since the detected rootfs device node $G_ROOTFS_DEV was not found, where we assume the image was started as container without block device access. You may want to open an issue at our GitHub or forum if this assumption is false.
\nIf this is a container, the journal can be created on the container host using the command \"tune2fs -j /dev/loop0p1\", with the loop device node as example. If this is a temporary image for testing or building, you may ignore this warning."
				fi
			fi

			# 1st run shaughvos-update
			if (( $G_SHAUGHVOS_INSTALL_STAGE == 0 ))
			then
				# Wait for network connectivity before attempting update (VMs may need time for DHCP)
				local max_wait=60 waited=0
				while (( waited < max_wait ))
				do
					# Check if we can resolve GitHub (lightweight DNS+TCP check)
					curl -sSfLm 5 -o /dev/null 'https://raw.githubusercontent.com' 2>/dev/null && break
					G_SHAUGHVOS-NOTIFY 2 "Waiting for network connectivity... (${waited}s/${max_wait}s)"
					G_SLEEP 5
					((waited+=5))
				done
				if (( waited >= max_wait ))
				then
					G_SHAUGHVOS-NOTIFY 1 'Network connectivity not established after 60s. Attempting update anyway...'
				fi

				# Start shaughvOS-Update
				/boot/shaughvos/shaughvos-update 1 2>&1 | tee "$FP_SHAUGHVOS_FIRSTRUNSETUP_LOG" # Sets /boot/shaughvos/.install_stage > G_SHAUGHVOS_INSTALL_STAGE=1

				# Prompt on failure
				(( $(</boot/shaughvos/.install_stage) == 1 )) || Prompt_on_Failure

			# 1st run shaughvos-software installs
			elif (( $G_SHAUGHVOS_INSTALL_STAGE == 1 ))
			then
				# Start shaughvOS-Software
				/boot/shaughvos/shaughvos-software 2>&1 | tee -a "$FP_SHAUGHVOS_FIRSTRUNSETUP_LOG" # Sets /boot/shaughvos/.install_stage > G_SHAUGHVOS_INSTALL_STAGE=2

				# Prompt on failure
				(( $(</boot/shaughvos/.install_stage) == 2 )) || Prompt_on_Failure
			fi

			# Exit script here is an automatic reboot is done
			G_CHECK_KERNEL || exit 0
		fi
	}

	Main()
	{
		# Prevent automated nested shaughvos-login calls from subshells
		export G_SHAUGHVOS_LOGIN=1

		while :
		do
			# Normal Login
			if [[ -f '/boot/shaughvos/.install_stage' && $(</boot/shaughvos/.install_stage) == 2 ]]
			then
				# Check user login passwords if first run setup was automated and hence created this flag, to prompt for a change if the default password is still used
				[[ $UID == 0 && -f '/var/lib/shaughvos/.check_user_passwords' ]] && /boot/shaughvos/func/shaughvos-set_software password users check

				# Show shaughvOS banner if not disabled via ~/.hushlogin
				[[ -f ~/.hushlogin ]] || /boot/shaughvos/func/shaughvos-banner 1

				# shaughvOS-AutoStart
				# - Skip if this is a desktop/X session already
				[[ $DISPLAY ]] && break
				# - Skip if autologin is not enabled
				[[ -f '/etc/systemd/system/getty@tty1.service.d/shaughvos-autologin.conf' ]] || break
				# - Skip if this is not the main TTY1
				[[ $(readlink -f /proc/$$/fd/1) == '/dev/tty1' ]] || break
				# - Skip if there is no shaughvOS-AutoStart config
				[[ -f '/boot/shaughvos/.shaughvos-autostart_index' ]] || break

				Run_AutoStart "$(</boot/shaughvos/.shaughvos-autostart_index)"
				break
			fi

			# Import shaughvOS-Globals -----------------------------------------
			. /boot/shaughvos/func/shaughvos-globals
			G_PROGRAM_NAME='shaughvOS-Login'
			#G_INIT
			# Import shaughvOS-Globals -----------------------------------------

			# First run setup
			if [[ $G_SHAUGHVOS_INSTALL_STAGE == [01] ]]
			then
				/boot/shaughvos/func/shaughvos-banner 0
				Run_shaughvOS_First_Run_Setup

			# Unknown install state
			else
				Prompt_on_Failure
			fi
		done
	}

	#/////////////////////////////////////////////////////////////////////////////////////
	# Main Loop
	#/////////////////////////////////////////////////////////////////////////////////////
	Main

	#-----------------------------------------------------------------------------------
	exit 0
	#-----------------------------------------------------------------------------------
}
