[Unit]
Description=shaughvOS-RAMlog
After=local-fs.target var-log.mount boot.mount -.mount
Before=syslog.service rsyslog.service

[Service]
Type=oneshot
RemainAfterExit=yes
ExecStartPre=/bin/mkdir -p /var/tmp/shaughvos/logs
ExecStart=/bin/dash -c '/boot/shaughvos/func/shaughvos-ramlog 0 >> /var/tmp/shaughvos/logs/shaughvos-ramlog.log 2>&1'
ExecStop=/bin/dash -c '/boot/shaughvos/func/shaughvos-ramlog 1 > /var/tmp/shaughvos/logs/shaughvos-ramlog.log 2>&1'

[Install]
WantedBy=multi-user.target
